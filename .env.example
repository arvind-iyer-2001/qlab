QLAB_Q_BINARY=/home/aiyer/.kx/bin/q
QLAB_DOCKER_IMAGE=qlab-judge
# Default/host license: a base64-encoded kc.lic key (q-solver style), used
# when a user has not uploaded their own. Passed to the judge container via
# the KDBLIC env var — no file on disk. Generate with: base64 -i kc.lic
QLAB_LICENSE_B64=
QLAB_JUDGE_TIMEOUT=10
# Container resource caps for untrusted user code (judge + /execute)
QLAB_DOCKER_MEMORY=256m
QLAB_DOCKER_CPUS=1
# Dev-only escape hatch: run the judge/runner on the local q binary (NO sandbox)
# when QLAB_DOCKER_IMAGE is unset. Leave EMPTY in prod — the judge fails closed
# without it rather than running untrusted code on the host. Set to 1 only on a
# trusted dev box that lacks docker.
QLAB_ALLOW_LOCAL_Q=
# Logging: format=json (default, one JSON line per record) or text (human dev).
# Every record carries the per-request X-Request-ID correlation id.
QLAB_LOG_FORMAT=json
QLAB_LOG_LEVEL=INFO
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=qlab
PROBLEMS_DIR=/home/aiyer/qlab/problems
CLERK_SECRET_KEY=sk_test_your_key_here
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=whsec_your_signing_secret_here
