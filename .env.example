QLAB_Q_BINARY=/home/aiyer/.kx/bin/q
QLAB_DOCKER_IMAGE=qlab-judge
# Host fallback license used when a user has not uploaded their own kc.lic.
# Prefer QLAB_LICENSE_B64 — a base64-encoded kc.lic key (like q-solver),
# passed to the judge container via the KDBLIC env var (no file mount).
# If unset, QLAB_KC_LIC points at a kc.lic file that is read and base64-encoded.
QLAB_LICENSE_B64=
QLAB_KC_LIC=~/.kx/kc.lic
QLAB_JUDGE_TIMEOUT=10
QLAB_NB_PORT=5001
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=qlab
PROBLEMS_DIR=/home/aiyer/qlab/problems
CLERK_SECRET_KEY=sk_test_your_key_here
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=whsec_your_signing_secret_here
